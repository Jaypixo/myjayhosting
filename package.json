{
  "name": "myjay",
  "version": "0.1.0",
  "private": true,
  "description": "MyJay: Neocities-style static site hosting on Cloudflare Pages, Workers, D1, R2, and KV.",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "wrangler pages dev public --compatibility-date=2024-01-01",
    "deploy": "wrangler pages deploy public",
    "db:init": "wrangler d1 execute myjay-db --file=schema/d1-init.sql",
    "db:init:local": "wrangler d1 execute myjay-db --local --file=schema/d1-init.sql",
    "router:dev": "wrangler dev worker/router.js",
    "router:deploy": "wrangler deploy worker/router.js --name myjay-router",
    "mailer:dev": "wrangler dev --config mailer/wrangler.toml",
    "mailer:deploy": "wrangler deploy --config mailer/wrangler.toml"
  },
  "devDependencies": {
    "wrangler": "^3.78.0",
    "marked": "^18.0.5"
  }
}
